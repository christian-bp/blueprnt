{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:reset": "bun run --cwd packages/backend db:reset",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@workspace/typescript-config": "workspace:*",
    "turbo": "^2.9.15",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.22",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "vitest": "4.1.8"
  }
}
