{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:reset": "bun run --cwd packages/backend db:reset",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@workspace/typescript-config": "workspace:*",
    "turbo": "^2.10.6",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "next": "16.2.11",
    "sharp": "0.35.0",
    "brace-expansion": "5.0.8",
    "fast-uri": "3.1.4",
    "js-yaml": "4.3.0",
    "body-parser": "2.3.0",
    "postcss": "8.5.18",
    "ws": "8.21.0"
  }
}
