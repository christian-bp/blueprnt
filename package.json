{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:reset": "bun run --cwd packages/backend db:reset",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@workspace/typescript-config": "workspace:*",
    "turbo": "^2.10.0",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "vitest": "4.1.9",
    "ws": "^8.21.0",
    "hono": "^4.12.25",
    "postcss": "^8.5.10",
    "esbuild": "^0.28.1"
  }
}
